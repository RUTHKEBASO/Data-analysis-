,"    </tr>\n","    <tr>\n","      <th>rating</th>\n","      <td>4</td>\n","    </tr>\n","    <tr>\n","      <th>duration</th>\n","      <td>3</td>\n","    </tr>\n","    <tr>\n","      <th>listed_in</th>\n","      <td>0</td>\n","    </tr>\n","    <tr>\n","      <th>description</th>\n","      <td>0</td>\n","    </tr>\n","  </tbody>\n","</table>\n","</div><br><label><b>dtype:</b> int64</label>"]},"metadata":{},"execution_count":36}]},{"cell_type":"code","source":["# checking for null values for columns with few null cells before droping the null values\n","print(df[['rating', 'duration', 'date_added']].isnull().sum())"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"qphDEbEV8oav","executionInfo":{"status":"ok","timestamp":1781169035635,"user_tz":-180,"elapsed":38,"user":{"displayName":"Dottie Kebbs","userId":"05568526357705980070"}},"outputId":"4759babb-f014-4fc4-8a5c-67ddae8fed9e"},"execution_count":37,"outputs":[{"output_type":"stream","name":"stdout","text":["rating         4\n","duration       3\n","date_added    10\n","dtype: int64\n"]}]},{"cell_type":"code","source":["df = df.dropna(subset=['rating'])      # drops 4 rows\n","df = df.dropna(subset=['duration'])    # drops 3 rows\n","df = df.dropna(subset=['date_added'])  # drops 10 rows\n","\n","print(\"After dropping:\", df.shape)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"hEX8uF4Y9FBr","executionInfo":{"status":"ok","timestamp":1781169153597,"user_tz":-180,"elapsed":47,"user":{"displayName":"Dottie Kebbs","userId":"05568526357705980070"}},"outputId":"d39c3580-f84a-4743-da43-0a8dd144ceda"},"execution_count":38,"outputs":[{"output_type":"stream","name":"stdout","text":["After dropping: (8790, 12)\n"]}]},{"cell_type":"code","source":["# Replace wrong rating values with NaN then fill with mode\n","import numpy as np\n","wrong_ratings = ['74 min', '84 min', '66 min']\n","df['rating'] = df['rating'].replace(wrong_ratings, np.nan)\n","df['rating'].fillna(df['rating'].mode()[0], inplace=True)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"hZ4g8drL-y7Q","executionInfo":{"status":"ok","timestamp":1781169611306,"user_tz":-180,"elapsed":47,"user":{"displayName":"Dottie Kebbs","userId":"05568526357705980070"}},"outputId":"aaf11116-d754-4573-835a-9579b4a64112"},"execution_count":39,"outputs":[{"output_type":"stream","name":"stderr","text":["/tmp/ipykernel_5488/1369477836.py:5: FutureWarning: A value is trying to be set on a copy of a DataFrame or Series through chained assignment using an inplace method.\n","The behavior will change in pandas 3.0. This inplace method will never work because the intermediate object on which we are setting values always behaves as a copy.\n","\n","For example, when doing 'df[col].method(value, inplace=True)', try using 'df.method({col: value}, inplace=True)' or df[col] = df[col].method(value) instead, to perform the operation inplace on the original object.\n","\n","\n","  df['rating'].fillna(df['rating'].mode()[0], inplace=True)\n"]}]},{"cell_type":"code","source":["# Split into number and unit\n","df['duration_value'] = df['duration'].str.extract(r'(\\d+)').astype(float)\n","df['duration_unit']  = df['duration'].str.extract(r'([a-zA-Z]+)')\n","\n","# Now you can separately analyze:\n","movies  = df[df['type'] == 'Movie']['duration_value'].mean()   # avg movie length\n","tvshows = df[df['type'] == 'TV Show']['duration_value'].mean() # avg seasons"],"metadata":{"id":"hF0t4YwI_KXi","executionInfo":{"status":"ok","timestamp":1781169700340,"user_tz":-180,"elapsed":40,"user":{"displayName":"Dottie Kebbs","userId":"05568526357705980070"}}},"execution_count":40,"outputs":[]},{"cell_type":"code","source":["# Currently looks like: \"Documentaries, International Movies\"\n","# Split and explode to analyze genres individually\n","df['genre'] = df['listed_in'].str.split(', ')\n","df_exploded = df.explode('genre')\n","print(df_exploded['genre'].value_counts().head(10))"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"2atGuQoH_eLH","executionInfo":{"status":"ok","timestamp":1781169781745,"user_tz":-180,"elapsed":315,"user":{"displayName":"Dottie Kebbs","userId":"05568526357705980070"}},"outputId":"945cee1f-3506-42ff-95f8-f4befe902612"},"execution_count":41,"outputs":[{"output_type":"stream","name":"stdout","text":["genre\n","International Movies        2752\n","Dramas                      2426\n","Comedies                    1674\n","International TV Shows      1349\n","Documentaries                869\n","Action & Adventure           859\n","TV Dramas                    762\n","Independent Movies           756\n","Children & Family Movies     641\n","Romantic Movies              616\n","Name: count, dtype: int64\n"]}]},{"cell_type":"markdown","source":["The donut chart illustrates the proportion of Movies and TV Shows in Netflix's content library, with Movies accounting for 69.7% and TV Shows for 30.3% of the 8,807 total titles."],"metadata":{"id":"x999nntNCgox"}},{"cell_type":"code","source":["type_counts = df['type'].value_counts()\n","\n","fig, ax = plt.subplots(figsize=(6, 5))\n","\n","ax.pie(\n","    type_counts,\n","    labels=type_counts.index,\n","    autopct='%1.1f%%',\n","    colors=['#3266ad', '#e07b4f'],\n","    startangle=90,\n","    wedgeprops={'edgecolor': 'white', 'linewidth': 3, 'width': 0.5}\n",")\n","\n","ax.text(0, 0, f'{len(df):,}', ha='center', va='center', fontsize=16, fontweight='bold')\n","plt.title(' Movies vs TV Shows distribution', fontsize=13, fontweight='bold')\n","plt.show()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":444},"id":"5_UNuzKyCdwZ","executionInfo":{"status":"ok","timestamp":1781170952392,"user_tz":-180,"elapsed":219,"user":{"displayName":"Dottie Kebbs","userId":"05568526357705980070"}},"outputId":"95d08e25-8aff-4780-97df-eb40dc23647a"},"execution_count":44,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 600x500 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"markdown","source":["The bar chart displays the top 10 countries by number of titles produced on Netflix. The United States leads significantly, followed by India and the United Kingdom."],"metadata":{"id":"55M6_7GfE9wR"}},{"cell_type":"code","source":["# Top 10 content-producing countries\n","country_counts = (df['country']\n","                  .str.split(',').str[0]  # take primary country only\n","                  .str.strip()\n","                  .value_counts()\n","                  .head(10))\n","\n","country_counts.sort_values().plot(\n","    kind='barh',\n","    figsize=(10, 6),\n","    color='#3266ad',\n","    edgecolor='white'\n",")\n","\n","plt.title('Top 10 content-producing countries on Netflix', fontsize=13, fontweight='bold')\n","plt.xlabel('Number of titles', fontsize=11)\n","plt.ylabel('Country', fontsize=11)\n","plt.tight_layout()\n","plt.show()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":397},"id":"3Zm66xtqE_Ya","executionInfo":{"status":"ok","timestamp":1781171241885,"user_tz":-180,"elapsed":2882,"user":{"displayName":"Dottie Kebbs","userId":"05568526357705980070"}},"outputId":"d297728d-0034-4838-f14e-e274995115bd"},"execution_count":45,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 1000x600 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"markdown","source":["From 2008 to 2019, Netflix steadily increased content additions each year, with Movies consistently outpacing TV Shows. Movies peaked in 2019 at 1,424 titles before slightly declining in 2020–2021, likely due to COVID-19 production disruptions. TV Shows followed the same upward trend but remained significantly lower, peaking at 595 titles in 2020."],"metadata":{"id":"8AeNlDwwHVSI"}},{"cell_type":"code","source":["df['year_added'] = df['date_added'].dt.year\n","yearly = df.groupby(['year_added', 'type']).size().unstack(fill_value=0)\n","\n","yearly.plot(kind='line', figsize=(10, 5), color=['#3266ad', '#e07b4f'],\n","            marker='o', linewidth=2)\n","\n","plt.title('Content added by year', fontsize=13, fontweight='bold')\n","plt.xlabel('Year')\n","plt.ylabel('Number of titles')\n","plt.legend(['Movies', 'TV Shows'])\n","plt.tight_layout()\n","plt.show()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":333},"id":"iqh3CH-sGn41","executionInfo":{"status":"ok","timestamp":1781171805978,"user_tz":-180,"elapsed":460,"user":{"displayName":"Dottie Kebbs","userId":"05568526357705980070"}},"outputId":"6f86957b-9a46-4670-a937-b1589988245f"},"execution_count":49,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 1000x500 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"markdown","source":["TV-MA is the most common rating with 3,205 titles, confirming Netflix's content is predominantly targeted at mature audiences. TV-14 follows at 2,157 titles. Child-friendly ratings such as TV-Y, PG, and TV-G are the least represented, indicating Netflix's library skews heavily toward adult and teenage viewers."],"metadata":{"id":"4MATc0IOH_SL"}},{"cell_type":"code","source":["rating_counts = df['rating'].value_counts().head(10)\n","\n","colors = ['#3266ad','#e07b4f','#1D9E75','#7F77DD','#D4537E',\n","          '#BA7517','#E24B4A','#0F6E56','#534AB7','#888780']\n","\n","rating_counts.plot(kind='bar', figsize=(10, 5), color=colors, edgecolor='white')\n","\n","plt.title('Most common ratings on Netflix', fontsize=13, fontweight='bold')\n","plt.xlabel('Rating')\n","plt.ylabel('Number of titles')\n","plt.xticks(rotation=45)\n","plt.tight_layout()\n","plt.show()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":333},"id":"ZTK6RYw7H5bj","executionInfo":{"status":"ok","timestamp":1781171989896,"user_tz":-180,"elapsed":467,"user":{"displayName":"Dottie Kebbs","userId":"05568526357705980070"}},"outputId":"60e7da79-0a9e-401d-dbd6-2db7210d6285"},"execution_count":50,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 1000x500 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"markdown","source":["The treemap visualises genre popularity by box size — the larger the box, the more titles in that genre. International Movies and Dramas dominate the space, while smaller genres like Romantic Movies and Children & Family occupy noticeably less area, making size differences instantly visible at a glance"],"metadata":{"id":"7KxpY2MTIx1g"}},{"cell_type":"code","source":["\n","!pip install squarify"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"xvFIsJm0IzBA","executionInfo":{"status":"ok","timestamp":1781172281680,"user_tz":-180,"elapsed":7319,"user":{"displayName":"Dottie Kebbs","userId":"05568526357705980070"}},"outputId":"6c1bfea7-0f64-4a93-8541-261dd43974f5"},"execution_count":52,"outputs":[{"output_type":"stream","name":"stdout","text":["Requirement already satisfied: squarify in /usr/local/lib/python3.12/dist-packages (0.4.4)\n"]}]},{"cell_type":"code","source":["import squarify\n","\n","# Get top 10 genres\n","genres = df['listed_in'].str.split(', ').explode().str.strip()\n","top_genres = genres.value_counts().head(10)\n","\n","colors = ['#3266ad','#e07b4f','#1D9E75','#7F77DD','#D4537E',\n","          '#BA7517','#E24B4A','#0F6E56','#534AB7','#888780']\n","\n","plt.figure(figsize=(12, 7))\n","\n","squarify.plot(\n","    sizes=top_genres.values,\n","    label=[f\"{genre}\\n{count:,}\" for genre, count in top_genres.items()],\n","    color=colors,\n","    alpha=0.85,\n","    edgecolor='white',\n","    linewidth=2,\n","    text_kwargs={'fontsize': 10, 'fontweight': 'bold', 'color': 'white'}\n",")\n","\n","plt.title('Most common Genre', fontsize=13, fontweight='bold')\n","plt.axis('off')\n","plt.tight_layout()\n","plt.show()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":727},"id":"nn07nBIKJBc4","executionInfo":{"status":"ok","timestamp":1781172340189,"user_tz":-180,"elapsed":367,"user":{"displayName":"Dottie Kebbs","userId":"05568526357705980070"}},"outputId":"6f9c7024-bdcd-4b14-abc9-34a114e9ad6c"},"execution_count":54,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 1200x700 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"markdown","source":["The heatmap reveals which ratings are most associated with each genre. Dramas and International Movies are heavily concentrated in TV-MA, confirming mature content dominates these genres. Children & Family Movies expectedly cluster under TV-G and TV-PG. International TV Shows are split almost equally between TV-14 and TV-MA, suggesting a wide range of maturity levels within that genre."],"metadata":{"id":"C5aCxrr4qfXq"}},{"cell_type":"code","source":["import seaborn as sns\n","\n","# Explode genres\n","genre_rating = df[['listed_in', 'rating']].copy()\n","genre_rating = genre_rating.assign(\n","    genre=genre_rating['listed_in'].str.split(', ')).explode('genre')\n","\n","# Top 10 genres and top 8 ratings only\n","top_genres  = genre_rating['genre'].value_counts().head(10).index\n","top_ratings = genre_rating['rating'].value_counts().head(8).index\n","\n","# Filter and pivot\n","heatmap_data = (genre_rating[\n","                    genre_rating['genre'].isin(top_genres) &\n","                    genre_rating['rating'].isin(top_ratings)]\n","                .groupby(['genre', 'rating'])\n","                .size()\n","                .unstack(fill_value=0))\n","\n","# Plot\n","plt.figure(figsize=(12, 7))\n","sns.heatmap(\n","    heatmap_data,\n","    annot=True,\n","    fmt='d',\n","    cmap='Blues',\n","    linewidths=0.5,\n","    linecolor='white'\n",")\n","\n","plt.title('Genre vs Rating heatmap', fontsize=13, fontweight='bold')\n","plt.xlabel('Rating')\n","plt.ylabel('Genre')\n","plt.xticks(rotation=45)\n","plt.yticks(rotation=0)\n","plt.tight_layout()\n","plt.show()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":410},"id":"c6V6aFa4qAzH","executionInfo":{"status":"ok","timestamp":1781180934338,"user_tz":-180,"elapsed":1409,"user":{"displayName":"Dottie Kebbs","userId":"05568526357705980070"}},"outputId":"50754f16-6582-4290-93ed-946f08477502"},"execution_count":55,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 1200x700 with 2 Axes>"],"image/png":"\n"},"metadata":{}}]}]}